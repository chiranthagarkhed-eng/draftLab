# Copy this file to .env and fill in your keys.
#
# RIOT_API_KEY  — required for the Python pipeline (data ingest) and the
#                 /api/pool route. Get one at https://developer.riotgames.com/
#                 (personal keys are free; they expire every 24 hours).
#
# ANTHROPIC_API_KEY — optional. Powers the streaming coaching commentary
#                     under each top recommendation. Without it, the app
#                     gracefully falls back to a structured engine breakdown.
#                     Get one at https://console.anthropic.com/

RIOT_API_KEY=RGAPI-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
